{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/kafka_in_nestjs/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/kafka_in_nestjs/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/kafka_in_nestjs",
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "kafka_in_nestjs": {
      "type": "application",
      "root": "apps/kafka_in_nestjs",
      "entryFile": "main",
      "sourceRoot": "apps/kafka_in_nestjs/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kafka_in_nestjs/tsconfig.app.json"
      }
    }
  }
}